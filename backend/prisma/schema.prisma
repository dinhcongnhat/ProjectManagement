generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum TaskType {
  ASSIGNED
  PERSONAL
}

enum ProjectStatus {
  IN_PROGRESS
  PENDING_APPROVAL
  COMPLETED
}

// Workflow status cho tracking 4 trạng thái công việc
enum WorkflowStatus {
  RECEIVED          // Đã nhận thông tin
  IN_PROGRESS       // Đang thực hiện
  COMPLETED         // Đã hoàn thành
  SENT_TO_CUSTOMER  // Đã gửi khách hàng
}

enum MessageType {
  TEXT
  VOICE
  FILE
  IMAGE
  VIDEO
  TEXT_WITH_FILE
  LINK
}

enum ConversationType {
  PRIVATE   // Chat 1-1
  GROUP     // Chat nhóm
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  position  String?
  avatar    String?  // Đường dẫn ảnh đại diện trong MinIO
  bio       String?  // Mô tả ngắn về bản thân
  phone     String?  // Số điện thoại
  email     String?  // Email
  lastActive DateTime @default(now()) // Thời gian hoạt động cuối
  isOnline   Boolean  @default(false)  // Trạng thái online
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTasks  Task[] @relation("CreatedTasks")
  assignedTasks Task[] @relation("AssignedTasks")

  managedProjects     Project[] @relation("ProjectManager")
  createdProjects     Project[] @relation("ProjectCreator")
  implementedProjects Project[] @relation("ProjectImplementers")
  followedProjects    Project[] @relation("ProjectFollowers")
  cooperatedProjects  Project[] @relation("ProjectCooperators")  // Phối hợp thực hiện
  
  messages   Message[]         @relation("UserMessages")
  activities ProjectActivity[] @relation("UserActivities")
  
  // Workflow approvals
  approvedWorkflows ProjectWorkflow[] @relation("WorkflowApprover")
  
  // Chat system
  conversations     ConversationMember[]
  chatMessages      ChatMessage[]       @relation("ChatMessageSender")
  createdConversations Conversation[]   @relation("ConversationCreator")
  chatReactions     ChatMessageReaction[] @relation("UserReactions")
  
  // Push notifications
  pushSubscriptions    PushSubscription[]
  notificationSettings NotificationSettings?
  
  // Personal folders
  userFolders UserFolder[] @relation("UserFolders")
  userFiles   UserFile[]   @relation("UserFiles")
  
  // Project attachments uploaded by this user
  uploadedAttachments ProjectAttachment[] @relation("UploadedAttachments")
  
  // Notifications
  notifications Notification[] @relation("UserNotifications")

  // Sharing
  sharedFolders UserFolderShare[] @relation("FolderShares")
  sharedFiles   UserFileShare[]   @relation("FileShares")

  // Google Drive
  googleIntegration GoogleIntegration?
  driveLinks        ProjectDriveLink[] @relation("DriveLinkAdder")

  // Kanban
  kanbanBoards       KanbanBoard[]       @relation("BoardOwner")
  kanbanBoardMembers KanbanBoardMember[]
  kanbanCardAssignees KanbanCard[]       @relation("CardAssignees")
  kanbanCardCreator  KanbanCard[]        @relation("CardCreator")
  kanbanComments     KanbanComment[]     @relation("CommentAuthor")
  kanbanAttachments  KanbanAttachment[]  @relation("KanbanAttachmentUploader")
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  type        TaskType   @default(ASSIGNED)
  startDate   DateTime?
  endDate     DateTime?
  note        String?    // Ghi chú của người dùng
  lastNoteAt  DateTime?  // Thời gian ghi chú cuối cùng
  reminderAt  DateTime?  // Thời gian nhắc nhở
  isReminderSent Boolean @default(false) // Trạng thái đã gửi nhắc nhở chưa
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  creatorId Int
  creator   User @relation("CreatedTasks", fields: [creatorId], references: [id])

  assigneeId Int?
  assignee   User? @relation("AssignedTasks", fields: [assigneeId], references: [id])
}

enum ProjectPriority {
  NORMAL
  HIGH
}

model Project {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  name           String
  investor       String?   // Chủ đầu tư
  startDate      DateTime?
  endDate        DateTime?
  duration       String?
  group          String?
  value          String?
  progressMethod String?
  description    String?
  attachment     String?
  progress       Float     @default(0)
  status         ProjectStatus @default(IN_PROGRESS)
  priority       ProjectPriority @default(NORMAL)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // New fields for sub-project (công việc con)
  documentNumber    String?   // Số hiệu văn bản
  documentDate      DateTime? // Ngày văn bản
  implementingUnit  String?   // Đơn vị thực hiện
  appraisalUnit     String?   // Đơn vị thẩm định
  approver          String?   // Người phê duyệt
  productType       String?   // Loại sản phẩm

  managerId Int
  manager   User @relation("ProjectManager", fields: [managerId], references: [id])

  createdById Int?        // Admin đã tạo dự án
  createdBy   User? @relation("ProjectCreator", fields: [createdById], references: [id])

  // Parent-Child relationship
  parentId  Int?
  parent    Project?  @relation("SubProjects", fields: [parentId], references: [id])
  children  Project[] @relation("SubProjects")

  implementers User[] @relation("ProjectImplementers")
  followers    User[] @relation("ProjectFollowers")
  cooperators  User[] @relation("ProjectCooperators")  // Phối hợp thực hiện
  
  messages     Message[]
  activities   ProjectActivity[]
  attachments  ProjectAttachment[]  // Multiple attachments support
  workflow     ProjectWorkflow?     // Workflow tracking
  notifications Notification[]      // Related notifications
  driveLinks   ProjectDriveLink[]   // Google Drive Links
}

// Project Attachments - Multiple files per project
// Admin uploads go to: DuAn/{TenDuAn}/TaiLieuDinhKem/
// Employee uploads go to: DuAn/{TenDuAn}/NhanVienDinhKem/
model ProjectAttachment {
  id          Int      @id @default(autoincrement())
  name        String   // Original filename
  minioPath   String   // Full path in MinIO
  fileType    String   // MIME type
  fileSize    Int      // Size in bytes
  category    String   // "TaiLieuDinhKem" (admin) or "NhanVienDinhKem" (employee)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Folder upload support
  isFolder       Boolean @default(false) // true if this is a folder entry
  folderName     String? // Root folder name (shared across all files in same folder upload)
  relativePath   String? // Relative path within the folder (e.g. "subfolder/file.txt")

  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploadedById Int
  uploadedBy   User @relation("UploadedAttachments", fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([uploadedById])
  @@index([folderName])
}

model Message {
  id          Int         @id @default(autoincrement())
  content     String?     // Text content (null for voice/file-only messages)
  messageType MessageType @default(TEXT)
  attachment  String?     // File path in MinIO (audio or other files)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  senderId Int
  sender   User @relation("UserMessages", fields: [senderId], references: [id])
}

model ProjectActivity {
  id        Int      @id @default(autoincrement())
  action    String   // e.g., "Updated progress to 75%", "Changed status to PENDING_APPROVAL"
  fieldName String?  // Field that was changed
  oldValue  String?  // Previous value
  newValue  String?  // New value
  createdAt DateTime @default(now())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation("UserActivities", fields: [userId], references: [id])
}

// ==================== CHAT SYSTEM ====================

model Conversation {
  id          Int              @id @default(autoincrement())
  name        String?          // Tên nhóm chat (null cho chat 1-1)
  type        ConversationType @default(PRIVATE)
  avatar      String?          // Ảnh đại diện nhóm
  description String?          // Mô tả nhóm
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdById Int
  createdBy   User @relation("ConversationCreator", fields: [createdById], references: [id])

  members  ConversationMember[]
  messages ChatMessage[]
}

model ConversationMember {
  id        Int      @id @default(autoincrement())
  joinedAt  DateTime @default(now())
  isAdmin   Boolean  @default(false)  // Admin của nhóm chat
  lastRead  DateTime @default(now())  // Thời điểm đọc tin nhắn cuối

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  content     String?     // Nội dung text
  messageType MessageType @default(TEXT)
  attachment  String?     // File path trong MinIO
  isRead      Boolean     @default(false)
  isForwarded Boolean     @default(false)  // Tin nhắn được chuyển tiếp
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId Int
  sender   User @relation("ChatMessageSender", fields: [senderId], references: [id])

  replyToId Int?
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("MessageReplies")
  
  reactions ChatMessageReaction[]
  
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}

// Reaction trên tin nhắn chat
model ChatMessageReaction {
  id        Int      @id @default(autoincrement())
  emoji     String   // Emoji: 👍 ❤️ 😂 😮 😢 😡
  createdAt DateTime @default(now())

  messageId Int
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// ==================== PUSH NOTIFICATIONS ====================

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String   // Public key
  auth      String   // Auth secret
  userAgent String?  // Browser/device info
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Notification preferences per user
model NotificationSettings {
  id                    Int      @id @default(autoincrement())
  chatMessages          Boolean  @default(true)
  projectAssignments    Boolean  @default(true)
  projectDiscussions    Boolean  @default(true)
  projectUpdates        Boolean  @default(true)
  taskAssignments       Boolean  @default(true)
  mentions              Boolean  @default(true)
  kanbanNotifications   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== USER PERSONAL FOLDERS ====================

model UserFolder {
  id          Int      @id @default(autoincrement())
  name        String   // Tên thư mục
  minioPath   String   // Đường dẫn trong MinIO (e.g., "users/nhatdc/Documents")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // User sở hữu thư mục
  userId Int
  user   User @relation("UserFolders", fields: [userId], references: [id], onDelete: Cascade)

  // Nested folders - parent/child relationship
  parentId Int?
  parent   UserFolder?  @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children UserFolder[] @relation("SubFolders")

  // Files trong thư mục này
  files UserFile[]

  // Shares
  shares UserFolderShare[]

  @@unique([userId, parentId, name]) // Tên thư mục unique trong cùng parent
  @@index([userId])
  @@index([parentId])
}

model UserFile {
  id          Int      @id @default(autoincrement())
  name        String   // Tên file gốc
  minioPath   String   // Đường dẫn trong MinIO
  fileType    String   // MIME type
  fileSize    Int      // Kích thước file (bytes)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // User sở hữu file
  userId Int
  user   User @relation("UserFiles", fields: [userId], references: [id], onDelete: Cascade)

  // Thư mục chứa file (null = root folder)
  folderId Int?
  folder   UserFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Shares
  shares UserFileShare[]

  @@index([userId])
  @@index([folderId])
}

// ==================== PROJECT WORKFLOW ====================
// Track 4 trạng thái công việc với ngày tháng chi tiết
model ProjectWorkflow {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId Int     @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Trạng thái hiện tại
  currentStatus WorkflowStatus @default(RECEIVED)

  // 1. Đã nhận thông tin
  receivedStartAt     DateTime?  // Ngày bắt đầu = ngày tạo project
  receivedConfirmedAt DateTime?  // Ngày kết thúc = khi ấn xác nhận

  // 2. Đang thực hiện
  inProgressStartAt     DateTime?  // = receivedConfirmedAt
  inProgressConfirmedAt DateTime?  // = khi ấn xác nhận

  // 3. Đã hoàn thành
  completedStartAt     DateTime?  // = inProgressConfirmedAt
  completedConfirmedAt DateTime?  // = khi ấn xác nhận (cần PM approve)
  completedApprovedById Int?      // PM đã approve
  completedApprovedBy   User?     @relation("WorkflowApprover", fields: [completedApprovedById], references: [id])
  completedApprovedAt  DateTime?  // Thời gian PM approve

  // 4. Đã gửi khách hàng
  sentToCustomerAt DateTime?  // = khi ấn xác nhận

  @@index([projectId])
}

// ==================== USER NOTIFICATIONS ====================
// Lưu trữ thông báo cho users
model Notification {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  // Loại thông báo
  type      String   // PROJECT_ASSIGNED, TASK_ASSIGNED, PROJECT_UPDATED, MESSAGE, etc.
  
  // Nội dung
  title     String   // Tiêu đề thông báo
  message   String   // Nội dung chi tiết
  
  // Link đến resource (optional)
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  taskId    Int?
  
  // Kanban deep-link info
  kanbanBoardId Int?
  kanbanCardId  Int?
  
  // User nhận thông báo
  userId    Int
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  // Trạng thái
  isRead    Boolean  @default(false)
  readAt    DateTime?
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== SHARING SYSTEM ====================

model UserFolderShare {
  id        Int      @id @default(autoincrement())
  folderId  Int
  folder    UserFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation("FolderShares", fields: [userId], references: [id], onDelete: Cascade)
  
  permission String  // 'VIEW', 'EDIT'
  createdAt  DateTime @default(now())

  @@unique([folderId, userId])
  @@index([userId])
  @@index([folderId])
}


model UserFileShare {
  id        Int      @id @default(autoincrement())
  fileId    Int
  file      UserFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation("FileShares", fields: [userId], references: [id], onDelete: Cascade)
  
  permission String  // 'VIEW', 'EDIT'
  createdAt  DateTime @default(now())

  @@unique([fileId, userId])
  @@index([userId])
  @@index([fileId])
}

// ==================== GOOGLE DRIVE INTEGRATION ====================

model GoogleIntegration {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiryDate   BigInt   // Token expiry timestamp
  email        String?  // Google email
  avatar       String?  // Google avatar url
  scope        String?  // Granted scopes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectDriveLink {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  fileId       String   // Google Drive File/Folder ID
  name         String
  mimeType     String
  webViewLink  String?
  iconLink     String?
  resourceType String   // 'file' | 'folder'
  
  addedByUserId Int
  addedBy       User     @relation("DriveLinkAdder", fields: [addedByUserId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([addedByUserId])
}

// ==================== KANBAN BOARD SYSTEM ====================

model KanbanBoard {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  background  String?  // Background color or image URL
  isProjectBoard Boolean @default(false) // Auto-created for project task tracking
  projectId  Int?      // Linked project
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId Int
  owner   User @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  lists   KanbanList[]
  members KanbanBoardMember[]
  labels  KanbanLabel[]

  @@index([ownerId])
  @@index([projectId])
}

model KanbanBoardMember {
  id        Int      @id @default(autoincrement())
  role      String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt  DateTime @default(now())

  boardId Int
  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model KanbanList {
  id        Int      @id @default(autoincrement())
  title     String
  position  Int      // Order of the list on the board
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId Int
  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards KanbanCard[]

  @@index([boardId])
}

model KanbanLabel {
  id    Int     @id @default(autoincrement())
  name  String?
  color String  // hex color

  boardId Int
  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards KanbanCard[] @relation("CardLabels")

  @@index([boardId])
}

model KanbanCard {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  position    Int       // Order of the card in the list
  dueDate     DateTime?
  completed   Boolean   @default(false)
  approved    Boolean   @default(false)  // Manager/reviewer approved this card
  approvedById Int?     // Who approved
  approvedAt DateTime?  // When approved
  deadlineReminderSent Boolean @default(false) // Track if 10-min reminder was sent
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Link to Task system (auto-created cards from task assignments)
  taskId     Int?       @unique
  // Link to Project (for project-based boards)
  projectId  Int?

  listId Int
  list   KanbanList @relation(fields: [listId], references: [id], onDelete: Cascade)

  creatorId Int
  creator   User @relation("CardCreator", fields: [creatorId], references: [id])

  assignees User[]         @relation("CardAssignees")
  labels    KanbanLabel[]  @relation("CardLabels")
  comments  KanbanComment[]
  checklist KanbanChecklist[]
  attachments KanbanAttachment[]

  @@index([listId])
  @@index([creatorId])
  @@index([taskId])
  @@index([projectId])
}

model KanbanComment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cardId Int
  card   KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  authorId Int
  author   User @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([cardId])
}

model KanbanChecklist {
  id        Int      @id @default(autoincrement())
  title     String
  checked   Boolean  @default(false)
  position  Int

  cardId Int
  card   KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model KanbanAttachment {
  id        Int      @id @default(autoincrement())
  fileName  String
  fileSize  Int
  mimeType  String
  minioPath String   // Path in MinIO storage
  source    String   @default("upload") // "upload", "folder", "google-drive"
  category  String   @default("attachment") // "attachment" or "completion"
  googleDriveFileId String? // For Google Drive files
  googleDriveLink   String? // Web view link for Google Drive files
  isFolder     Boolean  @default(false)
  folderName   String?
  relativePath String?
  createdAt DateTime @default(now())

  cardId Int
  card   KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  uploadedById Int
  uploadedBy   User @relation("KanbanAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([cardId])
  @@index([folderName])
}
